{
  "mcpServers": {
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "playwright-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp"],
      "env": {}
    },
    "notionMCP": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.notion.com/mcp"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"]
    },
    "microcms": {
      "command": "sh",
      "args": ["-c", "set -a && source .env.local && set +a && MICROCMS_SERVICE_ID=$MICROCMS_SERVICE_DOMAIN npx -y microcms-mcp-server@latest"]
    },
    "microcms-document": {
      "command": "npx",
      "args": ["-y", "microcms-document-mcp-server"]
    }
  }
}
